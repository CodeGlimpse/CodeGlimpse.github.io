&lt;/thead&gt;
&lt;tbody&gt;
&lt;tr&gt;
&lt;td&gt;InstallAllUsers&lt;/td&gt;
&lt;td&gt;Perform a system-wide installation.&lt;/td&gt;
&lt;td&gt;0&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td&gt;TargetDir&lt;/td&gt;
&lt;td&gt;The installation directory&lt;/td&gt;
&lt;td&gt;Selected based on InstallAllUsers&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td&gt;DefaultAllUsersTargetDir&lt;/td&gt;
&lt;td&gt;The default installation directory for all-user installs&lt;/td&gt;
&lt;td&gt;%ProgramFiles%\Python X.Y or %ProgramFiles(x86)%\Python X.Y&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td&gt;DefaultJustForMeTargetDir&lt;/td&gt;
&lt;td&gt;The default install directory for just-for-me installs&lt;/td&gt;
